# Server
SERVER_PORT=8080
GIN_MODE=release
FRONTEND_URL=http://localhost:3000

# Database (MySQL) — use DATABASE_URL (Railway) or DATABASE_DSN (direct)
DATABASE_URL=mysql://root:password@host:port/dbname
# DATABASE_DSN=root:root@tcp(localhost:3306)/auction?parseTime=true&loc=UTC

# Redis — use REDIS_URL (Railway) or REDIS_ADDR+REDIS_PASSWORD
REDIS_URL=redis://default:password@host:port
# REDIS_ADDR=localhost:6379
# REDIS_PASSWORD=

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=change-me-in-production

# TOTP 2FA (must be exactly 32 bytes for AES-256)
TOTP_AES_KEY=change-me-exactly-32-bytes-long!
TOTP_ISSUER=AuctionSystem

# Stripe Test Mode (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Cloudflare R2 / S3 (https://dash.cloudflare.com → R2)
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_BUCKET=auction
S3_ACCESS_KEY=xxx
S3_SECRET_KEY=xxx
S3_PUBLIC_URL=https://pub-xxx.r2.dev
